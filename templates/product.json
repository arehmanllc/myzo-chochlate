          }
        },
        "heading_4Be9TW": {
          "type": "heading",
          "settings": {
            "heading": "Meet the Heart Behind Myzo",
            "heading_size": "h2",
            "heading_clr": "",
            "heading_size_clr": "h1"
          }
        },
        "text_8ypkdM": {
          "type": "text",
          "settings": {
            "text": "<p>We’re Myzo Chocolate—a family-owned bean-to-bar chocolate company founded by a veteran’s family. We make our chocolate from the rare Matina variety of cacao beans (Criollo and Trinitario genome) sourced directly from Costa Rican farmers. No middlemen—just honest partnerships. Our chocolate is crafted with love in Ukraine, where we strive to create jobs, and have a positive socio-economic impact. We are building our brand from Miami, Florida from where we aim to share our craft with the world.</p>",
            "text_style": "body"
          }
        },
